---
// Gerado a partir de: index.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import LeadForm from '../components/forms/LeadForm.astro';
import Img from '../components/ui/Img.astro';
import Video from '../components/ui/Video.astro';
import '../styles/index.css';
---

<Base
  title="Casa Versatt | Eventos Corporativos na Zona Sul de São Paulo"
  ogImage="/images/og-index.jpg"
>
<!-- NAV -->
<nav id="nav">
  <div class="brand">Casa <b>Versatt</b></div>
  <div class="nav-links">
    <a href="#sobre">A casa</a>
    <a href="#estrutura">Estrutura</a>
    <a href="#tipos">Tipos de evento</a>
    <a href="#galeria">Galeria</a>
    <a href="#contato" class="nav-cta">Solicitar orçamento</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <Img src="hero-bg.jpg" alt="Casa Versatt — espaço para eventos corporativos" priority />
  </div>
  <div class="wrap">
    <div class="hero-copy">
      <span class="eyebrow">Eventos corporativos · Zona Sul SP</span>
      <h1 class="display">O cenário ideal para o <em>próximo passo</em> da sua empresa.</h1>
      <p class="lead">Um espaço para eventos corporativos que se adapta aos objetivos da sua empresa.</p>
      <a href="#contato" class="btn-primary">Solicite um orçamento <span class="arrow">&rarr;</span></a>
    </div>
  </div>
  <div class="scroll-hint">Role para descobrir<span></span></div>
</section>

<!-- SOBRE -->
<section class="sobre" id="sobre">
  <div class="wrap">
    <div class="sobre-top">
      <div class="reveal">
        <span class="eyebrow">A casa</span>
        <h2 class="title">O ambiente certo para aproximar equipes, clientes e oportunidades.</h2>
      </div>
      <div class="reveal">
        <p>Localizada na Zona Sul de São Paulo, a Casa Versatt foi criada para empresas que buscam mais do que um local para reunir pessoas. Com três pavimentos integrados e ambientes versáteis, o espaço oferece a liberdade necessária para transformar treinamentos, convenções, apresentações e confraternizações em experiências mais fluidas, organizadas e memoráveis.</p>
        <div class="guest-badge"><b>120 a 150</b><span>convidados por evento</span></div>
      </div>
    </div>
    <div class="video-frame reveal">
      <Video
        src="URL_DO_VIDEO_AQUI/casa-versatt-web.mp4"
        title="Casa Versatt — Espaço para eventos corporativos"
        description="Conheça os três andares da Casa Versatt, espaço para eventos corporativos na Zona Sul de São Paulo."
        uploadDate="2026-06-18"
        duration="PT5M25S"
      />
    </div>
  </div>
</section>

<!-- ESTRUTURA / CARROSSEL -->
<section id="estrutura">
  <div class="wrap">
    <div class="carousel-head">
      <div class="sec-head reveal" style="margin-bottom:0">
        <span class="eyebrow">Estrutura</span>
        <h2 class="title">Três andares, uma configuração para cada momento.</h2>
        <p>Elevador e escadas conectam todos os níveis, permitindo dividir cada momento da celebração sem que nada se misture.</p>
      </div>
      <div class="car-nav reveal">
        <button id="carPrev" aria-label="Anterior"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg></button>
        <button id="carNext" aria-label="Próximo"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></button>
      </div>
    </div>
    <div class="carousel reveal" id="carousel">
      <div class="slide"><Img src="estrutura-1.jpg" alt="Térreo — Casa Versatt" /></div>
      <div class="slide"><Img src="estrutura-2.jpg" alt="Primeiro andar — Casa Versatt" /></div>
      <div class="slide"><Img src="estrutura-3.jpg" alt="Rooftop — Casa Versatt" /></div>
      <div class="slide"><Img src="estrutura-4.jpg" alt="Circulação — Casa Versatt" /></div>
      <div class="slide"><Img src="estrutura-5.jpg" alt="Detalhe — Casa Versatt" /></div>
    </div>
  </div>
</section>

<!-- TIPOS DE EVENTOS -->
<section class="events" id="tipos">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Tipos de evento</span>
      <h2 class="title">Encontros que se adaptam às necessidades do seu time.</h2>
      <p>Recebemos desde reuniões reservadas até celebrações com a equipe inteira.</p>
    </div>
    <div class="egrid">
      <div class="eitem reveal"><div class="num">01</div><h3>Treinamentos e workshops</h3><p>Foco e conforto para o time aprender no andar reservado.</p></div>
      <div class="eitem reveal"><div class="num">02</div><h3>Convenções e plenárias</h3><p>Plateia acomodada e palco montado conforme o roteiro.</p></div>
      <div class="eitem reveal"><div class="num">03</div><h3>Lançamento de produto</h3><p>Recepção, demonstração e brinde em ambientes distintos.</p></div>
      <div class="eitem reveal"><div class="num">04</div><h3>Reuniões de diretoria</h3><p>Privacidade total para decisões estratégicas.</p></div>
      <div class="eitem reveal"><div class="num">05</div><h3>Confraternizações</h3><p>Happy hours e festas que aproximam quem trabalha junto.</p></div>
      <div class="eitem reveal"><div class="num">06</div><h3>Premiações e celebrações</h3><p>Reconhecimento com a cenografia que a data merece.</p></div>
    </div>
  </div>
</section>

<!-- INFRAESTRUTURA -->
<section id="infra">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Infraestrutura</span>
      <h2 class="title">Detalhes pensados para quem organiza.</h2>
      <p>Os seus convidados terão uma experiência premium do início ao fim.</p>
    </div>
    <div class="infra-grid">
      <div class="icard reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4"/></svg></div>
        <h3>Arquitetura clean</h3><p>Acabamento neutro que valoriza qualquer cenário.</p>
      </div>
      <div class="icard reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 12h3l3-9 6 18 3-9h3"/></svg></div>
        <h3>Acústica comprovada</h3><p>Som equilibrado para falas, vídeos e música.</p>
      </div>
      <div class="icard reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s-7-6.3-7-11a7 7 0 0114 0c0 4.7-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></div>
        <h3>Localização acessível</h3><p>Zona Sul, perto da Avenida do Cursino.</p>
      </div>
      <div class="icard reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="6" y="3" width="12" height="18" rx="2"/><path d="M9 7h6M9 11h6M9 15h2"/></svg></div>
        <h3>Elevador entre os níveis</h3><p>Circulação fácil para convidados e equipe.</p>
      </div>
      <div class="icard reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"/><path d="M12 3v18M4 7.5l8 4.5 8-4.5"/></svg></div>
        <h3>Curadoria de fornecedores</h3><p>Parceiros de confiança para toda a produção.</p>
      </div>
    </div>
  </div>
</section>

<!-- GALERIA -->
<section class="gallery" id="galeria">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">Galeria</span>
      <h2 class="title" style="margin-left:auto;margin-right:auto">Uma casa. Diversas possibilidades.</h2>
      <p>Explore os espaços que podem receber o seu próximo evento corporativo.</p>
    </div>
    <div class="gal-grid reveal">
      <Img src="galeria-1.jpg" alt="Casa Versatt — galeria 1" />
      <Img src="galeria-2.jpg" alt="Casa Versatt — galeria 2" />
      <Img src="galeria-3.jpg" alt="Casa Versatt — galeria 3" />
      <Img src="galeria-4.jpg" alt="Casa Versatt — galeria 4" />
      <Img src="galeria-5.jpg" alt="Casa Versatt — galeria 5" />
      <Img src="galeria-6.jpg" alt="Casa Versatt — galeria 6" />
      <Img src="galeria-7.jpg" alt="Casa Versatt — galeria 7" />
      <Img src="galeria-8.jpg" alt="Casa Versatt — galeria 8" />
      <Img src="galeria-9.jpg" alt="Casa Versatt — galeria 9" />
    </div>
  </div>
</section>

<!-- CONTATO -->
<section id="contato">
  <div class="wrap">
    <div class="contact-card reveal">
      <div class="contact-intro">
        <span class="eyebrow">Contato</span>
        <h2>Vamos planejar seu próximo encontro de sucesso?</h2>
        <p>Preencha o formulário para receber nosso contato.</p>
      </div>
      <LeadForm
        formId="lead-form"
        project={config.project_slug}
        submitUrl={config.forms['lead-form'].webhooks[0]}
        redirectUrl={config.forms['lead-form'].redirect_on_success}
        submitText="Enviar solicitação"
        honeypot
      />
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="wrap">
    <div class="foot">
      <div class="brand">Casa <b>Versatt</b></div>
      <p>Copyright © 2026 Casa Versatt. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>


</Base>
<script>
  import '../scripts/index.js';
</script>
